#!/usr/bin/env bash

history_file="${XDG_CACHE_HOME:-$HOME/.cache}/tm-sesh-history"

# tmux session names may not contain . or :
session_name() {
    basename "$1" | tr '.:' _
}

# Most recent picks first — dirs that still exist, session names still running
recent_picks() {
    [[ -f $history_file ]] || return 0
    while IFS= read -r entry; do
        if [[ $entry == /* ]]; then
            [[ -d $entry ]] && printf '%s\n' "$entry"
        else
            tmux has-session -t "=$entry" 2> /dev/null && printf '%s\n' "$entry"
        fi
    done < "$history_file"
}

remember() {
    mkdir -p "$(dirname "$history_file")"
    { printf '%s\n' "$1"; grep -vFx "$1" "$history_file" 2> /dev/null; } | head -20 > "$history_file.tmp"
    mv "$history_file.tmp" "$history_file"
}

# Recent picks, then project dirs, then any running sessions not already
# reachable through an earlier entry. Entries with a live session are
# marked ● — every line carries a two-column prefix, see strip_marker.
candidates() {
    {
        tmux list-sessions -F '#S' 2> /dev/null
        printf '\036\n'
        recent_picks
        find ~/work ~/personal -mindepth 1 -maxdepth 1 -type d
    } | awk -v mark="$(printf '\033[32m●\033[0m ')" -v home="$HOME" '
        $0 == "\036" { names_done = 1; next }
        !names_done { live[++n] = $0; is_live[$0] = 1; next }
        seen[$0]++ { next }
        {
            name = $0
            sub(/^.*\//, "", name)
            gsub(/[.:]/, "_", name)
            covered[name] = 1
            disp = $0
            if (index(disp, home "/") == 1) disp = "~" substr(disp, length(home) + 1)
            print (is_live[name] ? mark : "  ") disp
        }
        END { for (i = 1; i <= n; i++) if (!covered[live[i]]) print mark live[i] }
    '
}

# Undo the display formatting fzf hands back: drop the two-column prefix
# (ANSI already stripped by --ansi) and re-expand the leading ~
from_display() {
    local line=$1
    line=${line#'● '}
    line=${line#'  '}
    [[ $line == '~/'* ]] && line=$HOME/${line#'~/'}
    printf '%s\n' "$line"
}

# Live sessions preview their windows and what's on screen; unstarted
# dirs preview their contents
preview() {
    local entry=$1 name
    name=$(session_name "$entry")
    if tmux has-session -t "=$name" 2> /dev/null; then
        tmux list-windows -t "=$name" -F '#{?window_active,● ,  }#I: #W'
        echo
        tmux capture-pane -ep -t "=$name:"
    elif [[ $entry == /* ]]; then
        if command -v eza > /dev/null; then
            eza -a --group-directories-first --color=always "$entry"
        else
            ls -A "$entry"
        fi
    else
        echo "new session: $name"
    fi
}

if [[ $1 == --preview ]]; then
    preview "$(from_display "$2")"
    exit 0
fi

if [[ $1 == --list ]]; then
    candidates
    exit 0
fi

if [[ $# -eq 1 ]]; then
    selected=$1
else
    result=$(candidates | fzf --ansi --print-query --bind 'alt-enter:print-query' \
        --header 'enter: open · alt-enter: new session named after query' \
        --preview "'$0' --preview {}" --preview-window 'right,45%,border-left')
    [[ $? -eq 130 ]] && exit 0
    selected=$(sed -n 2p <<< "$result")
    if [[ -n $selected ]]; then
        selected=$(from_display "$selected")
    else
        selected=$(sed -n 1p <<< "$result")
    fi
fi

if [[ -z $selected ]]; then
    exit 0
fi

remember "$selected"

if [[ $selected == /* ]]; then
    session_dir=$selected
else
    session_dir=$HOME
fi
selected_name=$(session_name "$selected")
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$session_dir"
    exit 0
fi

if ! tmux has-session -t "=$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$session_dir"
fi

if [[ -z $TMUX ]]; then
    tmux attach -t "=$selected_name"
else
    tmux switch-client -t "=$selected_name"
fi
