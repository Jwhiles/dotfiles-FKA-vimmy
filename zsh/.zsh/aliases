alias foxdie='docker kill $(docker ps -q)'
alias unpushed='git branch --no-merged origin/main | grep -v "*"'
alias gfco='git fetch origin && git checkout'
alias john="tmuxinator start johncom"
alias coach="tmuxinator start coach"
alias ls='eza --git --icons --color=always --group-directories-first'
alias pr='gh pr create'
alias pro='gh pr view --web'
alias vim='nvim'
alias test-branch=yarn jest $(git diff main...HEAD --name-only --diff-filter=A | grep -E '\.(test|spec)\.(ts|tsx|js|jsx)$')

alias n='jj new'
alias s='jj st'
alias l='jj log'
alias m='jj describe'
alias d='jj diff'
alias e='jj edit'
alias p='jj git push'

clog() {
  obsidian daily:append content="$(date +%H:%M) $*"
}
